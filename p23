// Write a program to check whether a number is strong number or not
using System;
class Program
{
    static void Main()
    {
        int n, temp, sum = 0;
        Console.Write("Enter number: ");
        n = Convert.ToInt32(Console.ReadLine());
        temp = n;

        while (n > 0)
        {
            int fact = 1, rem = n % 10;

            for (int i = 1; i <= rem; i++)
                fact *= i;

            sum += fact;
            n /= 10;
        }

        if (sum == temp)
            Console.WriteLine("Strong Number");
        else
            Console.WriteLine("Not Strong");
    }
}
