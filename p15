#Sum of even numbers up to N
using System;
class Program
{
    static void Main()
    {
        int n, sum = 0;
        Console.Write("Enter N: ");
        n = Convert.ToInt32(Console.ReadLine());

        for (int i = 1; i <= n; i++)
        {
            if (i % 2 == 0)
                sum += i;
        }

        Console.WriteLine("Sum of even numbers = " + sum);
    }
}
