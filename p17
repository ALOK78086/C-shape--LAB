(* Count number of digits in a number *)
using System;
class Program
{
    static void Main()
    {
        int n, count = 0;
        Console.Write("Enter number: ");
        n = Convert.ToInt32(Console.ReadLine());

        while (n > 0)
        {
            count++;
            n = n / 10;
        }

        Console.WriteLine("Digits = " + count);
    }
}
