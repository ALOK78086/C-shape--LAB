// Write a program to find sum of factorial series
using System;
class Program
{
    static void Main()
    {
        int n;
        double sum = 0;

        Console.Write("Enter number: ");
        n = Convert.ToInt32(Console.ReadLine());

        for (int i = 1; i <= n; i++)
        {
            int fact = 1;
            for (int j = 1; j <= i; j++)
                fact *= j;

            sum += fact;
        }

        Console.WriteLine("Sum of factorial series = " + sum);
    }
}
